const reservationCancel = function() {
    location.href = "/" + locale + "/reservation/cove/room-search?memNo=" +roomInfo.memNo+"&arr="+roomInfo.arr+"&dep="+roomInfo.dep;
};

const isPhoneCheck = function(value) {
    var patternPhone = /01[016789][^0][0-9]{3,4}[0-9]{3,4}/;
    return patternPhone.test(value.replace(/-/gi, ''));
}
const isWhiteSpaceCheck = function(value) {
    return value.replace(/ /gi, "");
}
const gstChange = function(gst) {
    const no = gst.slice(0,-1);

    const reservationData = {
        bsns: '25',
        memNo: roomInfo.memNo,
        arr: moment(roomInfo.arr).format('YYYYMMDD'),
        dep: moment(roomInfo.dep).format('YYYYMMDD'),
        nig: roomInfo.nig,
        gst: no,
        rmtype: roomInfo.rmtype,
        roomRateCd: roomInfo.roomRateCd
    };

    $.ajax({
        url: "/reservation/cove/ajax/roomPrice",
        method: "post",
        type: "json",
        contentType: "application/json",
        data: JSON.stringify(reservationData),
        success: function (result) {
            // 성공
            var rate = result.data.rate;
            if(roomInfo.conYn =="Y"){
                rate = String(rate*2);
            }
            $("form[name='frmReservation']").find("input[name='rate']").val(result.data.rate);
            $("form[name='frmReservation']").find("input[name='gst']").val(no);
            $(".rate").html( rate.replace(/\B(?=(\d{3})+(?!\d))/g, ',')+"원")
        }
    });
};
