function fn_iframe_open(projectName, formName, datasetList, paramList, resFolio) {
    var _params = {"projectName":projectName //프로젝트명
        ,"formName":formName //서식명
        //t_000 : 상단 옵션 제어
        //r_000 : 우측 EUC 제어
        ,"UB_MENUCODE":"t_000,r_000"
        ,"UB_EMBED_VIEWER_MODE":"true"
        ,"FOLIONO":resFolio
    };

    for (var datasetValue in datasetList) {
        _params[datasetValue] = encodeURIComponent(datasetList[datasetValue]);
    }

    for (var paramValue in paramList) {
        _params[paramValue] = paramList[paramValue];
    }

    // var contextPath='';
    var _url = "http://report-server-2137341499.ap-northeast-2.elb.amazonaws.com:8080/UBIFORM/UView5/index.jsp";

    // 서버에 전송할 Parameter 처리
    var form = document.createElement("form");
    form.setAttribute("method", "get");
    form.setAttribute("action", _url);

    for (var i in _params)
    {
        if (_params.hasOwnProperty(i))
        {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = i;
            input.value = _params[i];
            form.appendChild(input);
        }
    }
    $("#eformDiv").append(form);
    // PDF파일을 받을수 있도록 IFrame를 Form에 Target로 지정
    form.setAttribute("target", "viwer_iFrame");               // 생성되어 있는 IFrame의 이름으로 지정
    if(document.getElementById("pdfIframe") == null){
        var vframe = document.createElement("iframe");
        vframe.setAttribute('id', "pdfIframe");
        vframe.setAttribute("name","viwer_iFrame");
        vframe.setAttribute("method", "post");
        //vframe.style.width = "1080px";
        //vframe.style.height = "1960px";
        vframe.style.width = "100%";
        vframe.style.height = "65vh";
        $("#eformDiv").append(vframe);
    }
    else{
        vframe = document.getElementById("pdfIframe");
    }

    // IFRAME Focus
    vframe.focus();
    // FORM 전송
    form.submit();

}
